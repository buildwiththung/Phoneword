<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Phoneword.MainPage">
    <VerticalStackLayout 
        Margin="20"
        Spacing="20">
        <Label Text="Enter a Phoneword" />
    
        <Entry Placeholder="1-555-NETMAUI" x:Name="PhoneNumberText" />
    
        <Button 
            x:Name="TranslateButton"
            Text="Translate"
            Clicked="OnTranslate"/>
        
        <Button 
            x:Name="CallButton"
            Text="Call"
            IsEnabled="False"
            Clicked="OnCall"/>
        
    </VerticalStackLayout>
    
</ContentPage>